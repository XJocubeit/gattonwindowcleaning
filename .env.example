# GWC CRM webhook — used by api/lead.js to forward leads server-side.
# Set these in Vercel → Project → Settings → Environment Variables.
# Never commit real values to git.

# Required: the x-gwc-secret header value (provided by the CRM owner).
LEAD_WEBHOOK_SECRET=

# Optional: override the CRM webhook URL (defaults to production).
# LEAD_WEBHOOK_URL=https://crm.gattonwindowcleaning.app/api/webhook/lead
